\name{extractionengine-package}
\alias{extractionengine-package}
\alias{extractionengine}
\docType{package}
\title{Auditable execution of study variable definitions}
\description{
\pkg{extractionengine} executes explicit operational definitions over prepared
EDSAN views and keeps values, source coverage, evidence, and provenance together.
The researcher remains responsible for scientific and clinical correctness.
}
\details{
\pkg{redsan} owns EDSAN retrieval and normalization. \pkg{ellmer} owns model
transport and structured responses. This package compiles and audits the study
definition that connects those boundaries.
}
\keyword{package}
